rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Categories: read all, write admin
    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products: read all, write admin
    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Branches: read all, write admin
    match /branches/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: read own, write own
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Orders: users see own, admins see all
    match /orders/{docId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.user_id || isAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.user_id || isAdmin()
      );
    }

    // Installation bookings
    match /installation_bookings/{docId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.user_id
        || request.auth.uid == resource.data.assigned_installer_id
        || isAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.user_id
        || request.auth.uid == resource.data.assigned_installer_id
        || isAdmin()
      );
    }

    // CMS pages: read all, write admin
    match /cms_pages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CRM: admin only
    match /crm_interactions/{docId} {
      allow read, write: if isAdmin();
    }

    match /crm_tasks/{docId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.assigned_to || isAdmin()
      );
      allow write: if isAdmin();
    }

    // Helper function
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
